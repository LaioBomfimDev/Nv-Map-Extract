{
  "name": "friendly-miner",
  "version": "1.0.0",
  "description": "Friendly Miner - Painel React com Supabase para mineracao e analise geografica de leads do Google Maps",
  "main": "index.js",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "cd frontend && npm start",
    "legacy:backend": "cd backend && npm start",
    "legacy:full": "concurrently \"npm run legacy:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm run build",
    "release:extension": "node scripts/release-extension.mjs",
    "validate:extension-release": "node scripts/release-extension.mjs --validate",
    "install:all": "npm install",
    "vercel-build": "cd frontend && npm ci && npm run build"
  },
  "keywords": [
    "google-maps",
    "scraping",
    "dashboard",
    "react",
    "supabase",
    "chrome-extension"
  ],
  "author": "LaioBomfimDev",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^7.6.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
